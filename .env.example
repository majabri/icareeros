# iCareerOS — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.

# Anthropic Claude API (server-side only — never expose to client)
ANTHROPIC_API_KEY=sk-ant-xxxxx...

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# GitHub
GH_TOKEN=ghp_xxxxx...

# Vercel
VERCEL_TOKEN=xxx_xxxxx...

# Stripe (add when billing is configured)
STRIPE_SECRET_KEY=sk_live_xxxxx...
STRIPE_WEBHOOK_SECRET=whsec_xxxxx...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx...

# ─────────────────────────────────────────────────────────────
# Observability (Day 32)
# ─────────────────────────────────────────────────────────────

# Sentry — create a project at https://sentry.io and copy the DSN from
# Settings → Projects → <project> → Client Keys.
# NEXT_PUBLIC_SENTRY_DSN is used by the browser bundle (client config).
# SENTRY_DSN is used by Node/Edge runtimes (server + edge config).
# Both point to the same DSN — separate vars allow different scopes.
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN=https://xxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# Sentry build-time vars — required for source map upload to Sentry.
# Auth token: Settings → Auth Tokens → Create new token (scope: project:releases + org:read).
SENTRY_AUTH_TOKEN=sntrys_xxxxx...
SENTRY_ORG=jabri-solutions
SENTRY_PROJECT=icareeros

# App environment label — shown in Sentry dashboard.
# Set to "production" on Vercel prod, "staging" on Vercel preview.
NEXT_PUBLIC_APP_ENV=development

# App version — auto-set by CI from git SHA; leave blank locally.
NEXT_PUBLIC_APP_VERSION=

# BetterStack — Uptime
# Source token from BetterStack → Uptime → Monitors → New monitor.
# Used only if you add server-side log forwarding via Logtail (optional).
BETTERSTACK_API_KEY=xxxxx...

# ─────────────────────────────────────────────────────────────
# Email — Bluehost SMTP (Job Alerts cron + future transactional mail)
# ─────────────────────────────────────────────────────────────

# Bluehost SMTP credentials — use port 465 (SSL) or 587 (STARTTLS).
BLUEHOST_SMTP_HOST=mail.icareeros.com
BLUEHOST_SMTP_PORT=465
BLUEHOST_SMTP_USER=bugs@icareeros.com
BLUEHOST_SMTP_PASS=your-bluehost-email-password

# Display "from" address for alert emails.
# Defaults to BLUEHOST_SMTP_USER if not set.
ALERT_FROM_EMAIL=bugs@icareeros.com

# ─────────────────────────────────────────────────────────────
# Vercel Cron — Job Alerts (/api/cron/job-alerts)
# ─────────────────────────────────────────────────────────────

# Random secret to authenticate the Vercel Cron caller.
# Generate with: openssl rand -hex 32
# Add the same value in Vercel → Settings → Environment Variables.
CRON_SECRET=your-random-secret-here

# ─── Integrations (optional — adapters show "Coming soon" when absent) ─────────
# LinkedIn API v2 — request access at https://developer.linkedin.com/
# Upstash Redis (optional — falls back to in-memory LRU cache in dev/CI)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

LINKEDIN_API_KEY=

# Indeed Publisher API — request at https://ads.indeed.com/jobroll/xmlfeed
INDEED_PUBLISHER_ID=

# ─── Langfuse LLM Observability (optional — routes work without these) ────────
# Get keys at https://cloud.langfuse.com → Settings → API Keys
# Self-hosted: set LANGFUSE_BASE_URL to your instance (e.g. https://langfuse.example.com)
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx...
LANGFUSE_SECRET_KEY=sk-lf-xxxxx...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
